{
    "config": {
        "abort": {
            "single_instance_allowed": "The CronoStar global component is already installed."
        },
        "step": {
            "user": {
                "title": "CronoStar Setup",
                "menu_options": {
                    "controller": "Add a new Controller"
                }
            },
            "install_component": {
                "description": "This will install the CronoStar component and register the global services and Lovelace card resource.",
                "title": "Install CronoStar"
            },
            "controller": {
                "title": "Configure CronoStar Controller",
                "description": "Set up a new controller for your time-based schedule.\n\nThe **Global Prefix** will be used to generate helper entities (profile select, pause switch).",
                "data": {
                    "name": "Controller Name",
                    "preset_type": "Preset Type",
                    "target_entity": "Target Entity",
                    "global_prefix": "Global Prefix",
                    "logging_enabled": "Enable Debug Logging"
                }
            },
            "card_config": {
                "title": "CronoStar Card Configuration {tag}",
                "description": "Configure the default appearance and limits for the Lovelace card associated with this controller.\n\nPreset: **{preset}**",
                "data": {
                    "title": "Card Title",
                    "min_value": "Minimum Value",
                    "max_value": "Maximum Value",
                    "step_value": "Step Value",
                    "unit_of_measurement": "Unit of Measurement",
                    "y_axis_label": "Y-Axis Label",
                    "allow_max_value": "Allow 'Max' Value",
                    "logging_enabled": "Enable Debug Logging",
                    "language": "UI Language"
                }
            },
            "success": {
                "title": "Configuration Complete {confirm_tag}",
                "description": "The controller '{name}' has been successfully configured.\n\nYou can now add the CronoStar card to your dashboard using the prefix and target entity defined."
            }
        }
    },
    "options": {
        "step": {
            "init": {
                "data": {
                    "name": "Controller Name",
                    "preset_type": "Preset Type",
                    "target_entity": "Target Entity",
                    "global_prefix": "Global Prefix",
                    "logging_enabled": "Enable Debug Logging",
                    "language": "UI Language"
                },
                "description": "Configure settings for this CronoStar controller.",
                "title": "CronoStar Options [v5.4.72]"
            },
            "card_config": {
                "title": "CronoStar Card Configuration {tag} [v5.4.72]",
                "description": "Update the default appearance and limits for the Lovelace card.\n\nPreset: **{preset}**",
                "data": {
                    "title": "Card Title",
                    "min_value": "Minimum Value",
                    "max_value": "Maximum Value",
                    "step_value": "Step Value",
                    "unit_of_measurement": "Unit of Measurement",
                    "y_axis_label": "Y-Axis Label",
                    "allow_max_value": "Allow 'Max' Value",
                    "logging_enabled": "Enable Debug Logging",
                    "language": "UI Language"
                }
            },
            "success": {
                "title": "Settings Updated {confirm_tag}",
                "description": "The configuration has been successfully updated."
            }
        }
    },
    "selector": {
        "language": {
            "options": {
                "default": "System Default",
                "en": "English",
                "it": "Italiano"
            }
        }
    },
    "exceptions": {
        "profile_not_found": {
            "message": "Profile {profile} not found for {preset} (Prefix: {prefix})."
        },
        "schedule_application_error": {
            "message": "Failed to apply schedule to {entity}: {error}"
        }
    },
